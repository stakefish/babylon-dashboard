{
  "name": "@services/simple-staking",
  "version": "1.0.9",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--max-old-space-size=8192 pnpm exec vite",
    "watchDeps": "./scripts/watch-deps.sh @services/simple-staking",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 pnpm exec tsc --noEmit -p tsconfig.lib.json && NODE_OPTIONS=--max-old-space-size=8192 pnpm exec vite build",
    "build:ci": "NODE_OPTIONS=--max-old-space-size=4096 pnpm exec vite build",
    "lint": "eslint",
    "preview": "vite preview",
    "build:e2e": "NODE_OPTIONS=--max-old-space-size=8192 pnpm exec vite build --mode test",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "clean": "rm -r node_modules",
    "build-docker": "docker build -t babylonlabs/simple-staking -f docker/Dockerfile .",
    "clean-docker": "docker rmi babylonlabs/simple-staking 2>/dev/null; true",
    "prepare": "husky",
    "sort-imports": "eslint --fix .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test e2e/specs/",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "visualizer": "pnpm exec vite-bundle-visualizer",
    "gen:api": "pnpm exec swagger-typescript-api generate -p https://staking-api.babylonlabs.io/swagger/doc.json -o ./src/shared/utils/swagger -t ./src/shared/utils/swagger/templates -n api.ts --unwrap-response-data --disable-format --silent"
  },
  "dependencies": {
    "@babylonlabs-io/babylon-proto-ts": "workspace:*",
    "@babylonlabs-io/btc-staking-ts": "2.8.6",
    "@babylonlabs-io/core-ui": "workspace:*",
    "@babylonlabs-io/wallet-connector": "workspace:*",
    "@bitcoin-js/tiny-secp256k1-asmjs": "2.2.3",
    "@cosmjs/proto-signing": "0.36.0",
    "@cosmjs/stargate": "0.36.0",
    "@cosmjs/tendermint-rpc": "0.36.0",
    "@reown/appkit": "1.8.12",
    "@stakefish/ui-kit": "1.3.9",
    "@tanstack/react-query": "^5.74.4",
    "awilix": "12.0.5",
    "bitcoinjs-lib": "6.1.7",
    "clsx": "^2.1.1",
    "core-js": "3.41.0",
    "cosmjs-types": "^0.10.1",
    "date-fns": "3.6.0",
    "decimal.js-light": "2.5.1",
    "idb": "8.0.3",
    "mixpanel-browser": "^2.77.0",
    "nanoevents": "9.1.0",
    "next-themes": "0.3.0",
    "qs": "6.14.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-error-boundary": "6.0.0",
    "react-hook-form": "7.54.0",
    "react-icons": "5.3.0",
    "react-infinite-scroll-component": "6.1.0",
    "react-router": "7.12.0",
    "react-toastify": "10.0.6",
    "react-tooltip": "5.29.1",
    "sharp": "0.33.4",
    "tailwind-merge": "2.5.4",
    "tw-colors": "3.3.2",
    "url-safe-base64": "1.3.0",
    "usehooks-ts": "^3.1.1",
    "uuid": "11.1.0",
    "viem": "^2.38.2",
    "wagmi": "2.18.1",
    "yup": "1.6.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.7",
    "@babel/preset-env": "^7.24.7",
    "@babel/preset-react": "^7.24.7",
    "@babel/preset-typescript": "^7.24.7",
    "@eslint/js": "^9.31.0",
    "@playwright/test": "^1.55.1",
    "@tanstack/eslint-plugin-query": "^5.74.7",
    "@tanstack/react-query-devtools": "5.28.14",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.10.2",
    "@types/qs": "^6.9.17",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.20",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "ecpair": "^2.1.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.3.5",
    "eslint-plugin-import-x": "^4.15.2",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.5.0",
    "msw": "^2.0.0",
    "postcss": "^8.4.47",
    "postcss-import": "^16.1.0",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "sass-embedded": "^1.98.0",
    "source-map-loader": "^5.0.0",
    "swagger-typescript-api": "^13.1.1",
    "tailwindcss": "^3.4.14",
    "text-encoding": "^0.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vite": "^6.4.1",
    "vite-plugin-environment": "^1.1.3",
    "vite-plugin-node-polyfills": "^0.23.0",
    "vite-plugin-radar": "^0.10.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "overrides": {
    "tr46": "4.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --quiet --fix"
    ],
    "*.{js,jsx,ts,tsx,json,css,scss,md,yml,yaml}": [
      "prettier --write --ignore-unknown"
    ]
  }
}
