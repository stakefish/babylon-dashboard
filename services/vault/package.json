{
  "name": "@services/vault",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--max-old-space-size=8192 pnpm exec vite",
    "watchDeps": "./scripts/watch-deps.sh @services/vault",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 pnpm exec tsc --noEmit -p tsconfig.lib.json && NODE_OPTIONS=--max-old-space-size=8192 pnpm exec vite build",
    "lint": "eslint",
    "preview": "vite preview",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "clean": "rm -r node_modules",
    "sort-imports": "eslint --fix .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@babylonlabs-io/config": "workspace:*",
    "@babylonlabs-io/core-ui": "workspace:*",
    "@babylonlabs-io/ts-sdk": "workspace:*",
    "@babylonlabs-io/wallet-connector": "workspace:*",
    "@bitcoin-js/tiny-secp256k1-asmjs": "2.2.3",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/modifiers": "9.0.0",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@metamask/browser-passworder": "6.0.0",
    "@noble/hashes": "2.0.1",
    "@scure/bip39": "2.0.1",
    "@tanstack/react-query": "^5.74.4",
    "bitcoinjs-lib": "6.1.7",
    "buffer": "6.0.3",
    "graphql": "^16.12.0",
    "graphql-request": "^7.3.4",
    "next-themes": "0.3.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-error-boundary": "6.0.0",
    "react-icons": "5.3.0",
    "react-router": "7.12.0",
    "react-toastify": "10.0.6",
    "react-tooltip": "5.29.1",
    "tailwind-merge": "2.5.4",
    "usehooks-ts": "^3.1.1",
    "uuid": "11.1.0",
    "viem": "^2.38.2",
    "wagmi": "2.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@playwright/test": "^1.55.1",
    "@tanstack/react-query-devtools": "5.28.14",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/ui": "^4.0.8",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.3.5",
    "eslint-plugin-import-x": "^4.15.2",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "postcss": "^8.4.47",
    "postcss-import": "^16.1.0",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "^3.4.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vite": "^6.4.1",
    "vite-plugin-environment": "^1.1.3",
    "vite-plugin-node-polyfills": "^0.23.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.8"
  }
}
