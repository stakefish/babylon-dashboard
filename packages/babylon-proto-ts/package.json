{
  "name": "@babylonlabs-io/babylon-proto-ts",
  "version": "0.0.0-semantic-release",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b --noEmit tsconfig.lib.json && vite build",
    "build:ci": "vite build",
    "build-proto": "node scripts/build-proto.js",
    "format": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\""
  },
  "files": [
    "dist",
    "dist/**/*.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/babylonlabs-io/babylon-toolkit.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@bufbuild/buf": "^1.45.0",
    "@internal/eslint-config": "workspace:*",
    "cosmjs-types": "^0.10.1",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.1.0",
    "shelljs": "^0.8.5",
    "typescript": "^5.8.3",
    "vite": "^6.4.1",
    "vite-plugin-dts": "^4.3.0",
    "vite-plugin-node-polyfills": "^0.23.0"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.2.0",
    "@cosmjs/proto-signing": "0.36.0",
    "@cosmjs/stargate": "0.36.0",
    "@cosmjs/tendermint-rpc": "0.36.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
