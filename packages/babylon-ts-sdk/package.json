{
  "name": "@babylonlabs-io/ts-sdk",
  "version": "0.1.2",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=20.3.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    },
    "./tbv": {
      "types": "./dist/tbv/index.d.ts",
      "require": "./dist/tbv/index.cjs",
      "import": "./dist/tbv/index.js"
    },
    "./tbv/core": {
      "types": "./dist/tbv/core/index.d.ts",
      "require": "./dist/tbv/core/index.cjs",
      "import": "./dist/tbv/core/index.js"
    },
    "./tbv/core/primitives": {
      "types": "./dist/tbv/core/primitives/index.d.ts",
      "require": "./dist/tbv/core/primitives/index.cjs",
      "import": "./dist/tbv/core/primitives/index.js"
    },
    "./tbv/core/utils": {
      "types": "./dist/tbv/core/utils/index.d.ts",
      "require": "./dist/tbv/core/utils/index.cjs",
      "import": "./dist/tbv/core/utils/index.js"
    },
    "./tbv/core/clients": {
      "types": "./dist/tbv/core/clients/index.d.ts",
      "require": "./dist/tbv/core/clients/index.cjs",
      "import": "./dist/tbv/core/clients/index.js"
    },
    "./tbv/core/services": {
      "types": "./dist/tbv/core/services/index.d.ts",
      "require": "./dist/tbv/core/services/index.cjs",
      "import": "./dist/tbv/core/services/index.js"
    },
    "./tbv/core/vault-secrets": {
      "types": "./dist/tbv/core/vault-secrets/index.d.ts",
      "require": "./dist/tbv/core/vault-secrets/index.cjs",
      "import": "./dist/tbv/core/vault-secrets/index.js"
    },
    "./tbv/integrations/aave": {
      "types": "./dist/tbv/integrations/aave/index.d.ts",
      "require": "./dist/tbv/integrations/aave/index.cjs",
      "import": "./dist/tbv/integrations/aave/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "require": "./dist/shared/index.cjs",
      "import": "./dist/shared/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "require": "./dist/testing/index.cjs",
      "import": "./dist/testing/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b --noEmit tsconfig.lib.json && vite build",
    "format": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "docs:generate": "typedoc",
    "docs:clean": "rm -rf docs/api && pnpm docs:generate",
    "docs:validate": "typedoc --emit none"
  },
  "files": [
    "dist",
    "dist/**/*.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/babylonlabs-io/babylon-toolkit.git"
  },
  "keywords": [
    "babylon",
    "bitcoin",
    "vault",
    "tbv",
    "trustless-bitcoin-vault",
    "staking",
    "defi"
  ],
  "author": "",
  "license": "ISC",
  "description": "TypeScript SDK for Babylon protocol integrations",
  "dependencies": {
    "@babylonlabs-io/babylon-tbv-rust-wasm": "workspace:*",
    "@noble/hashes": "2.0.1",
    "@scure/bip39": "2.0.1",
    "buffer": "6.0.3"
  },
  "peerDependencies": {
    "@bitcoin-js/tiny-secp256k1-asmjs": "2.2.3",
    "bitcoinjs-lib": "6.1.7",
    "viem": "^2.38.2"
  },
  "devDependencies": {
    "@internal/eslint-config": "workspace:*",
    "@vitest/coverage-v8": "^4.0.8",
    "@vitest/ui": "^4.0.8",
    "eslint-plugin-jsdoc": "^50.6.17",
    "eslint-plugin-tsdoc": "^0.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.1.0",
    "typedoc": "^0.28.5",
    "typedoc-plugin-markdown": "^4.6.3",
    "typescript": "^5.8.3",
    "viem": "^2.38.2",
    "vite": "^6.4.1",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^4.0.8"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
